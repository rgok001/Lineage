# Copy to .env and fill in. Never commit .env.

# Postgres. Primary: a Neon connection string (Dashboard > Connect > psql).
# Neon supports pgvector, so migration 001 runs against it unchanged.
# Append ?sslmode=require if the string doesn't already include it.
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
# Local fallback (needs Docker Desktop + `docker compose up -d`):
# DATABASE_URL=postgresql://lineage:lineage@localhost:5432/lineage

# LLM pipeline
ANTHROPIC_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
# Model for Stage B extraction. Default claude-opus-4-8; claude-sonnet-5 matched
# it on the showcase papers at ~60% the cost. Not part of the extraction cache
# key — bump PROMPT_VERSION to force re-extraction with a different model.
LLM_MODEL=claude-sonnet-5

# OpenAlex polite pool — identifies us and gets better rate limits
OPENALEX_MAILTO=ravi.gokal@gmail.com

# Cost discipline: abort any trace that would exceed this (USD)
TRACE_SPEND_CAP_USD=10

# Bump to invalidate per-paper extraction caches
PROMPT_VERSION=v1

# Where raw tex/pdf and extracted text are stored
DATA_DIR=./data

# ── App auth (app/.env.local, not this file) ─────────────────────────────
# Register a GitHub OAuth app: Settings > Developer settings > OAuth Apps.
# Callback URL: http://localhost:3000/api/auth/callback/github
#   AUTH_GITHUB_ID=...
#   AUTH_GITHUB_SECRET=...
#   AUTH_SECRET=...              generated by app/scripts/gen-auth-secret.mjs
#   OWNER_GITHUB_LOGIN=rgok001   only this login may edit; unset = nobody can
