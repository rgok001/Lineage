# Copy to .env and fill in. Never commit .env.

# Postgres. Primary: a Neon connection string (Dashboard > Connect > psql).
# Neon supports pgvector, so migration 001 runs against it unchanged.
# Append ?sslmode=require if the string doesn't already include it.
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
# Local fallback (needs Docker Desktop + `docker compose up -d`):
# DATABASE_URL=postgresql://lineage:lineage@localhost:5432/lineage

# LLM pipeline
ANTHROPIC_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex polite pool — identifies us and gets better rate limits
OPENALEX_MAILTO=ravi.gokal@gmail.com

# Cost discipline: abort any trace that would exceed this (USD)
TRACE_SPEND_CAP_USD=10

# Bump to invalidate per-paper extraction caches
PROMPT_VERSION=v1

# Where raw tex/pdf and extracted text are stored
DATA_DIR=./data
